{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git"
      ]
    }
  ],
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "kitchenguard-8e288",
          "appId": "1:82695156984:android:99963a2270a7f729fbf70d",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "kitchenguard-8e288",
          "appId": "1:82695156984:ios:f7741ab7b891fe51fbf70d",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "kitchenguard-8e288",
          "configurations": {
            "android": "1:82695156984:android:99963a2270a7f729fbf70d",
            "ios": "1:82695156984:ios:f7741ab7b891fe51fbf70d",
            "web": "1:82695156984:web:cf3ca9d1d6ffea98fbf70d"
          }
        }
      }
    }
  }
}
